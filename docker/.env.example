# Copy this to docker/.env and fill in values
# Run from the docker/ folder: docker compose --env-file .env up --build

POSTGRES_PASSWORD=changeme_use_strong_password

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_64_char_random_hex_string

OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
DEBUG=false
