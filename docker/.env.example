# ─────────────────────────────────────────────────────────
# Production environment — copy to docker/.env and fill in
#   cp docker/.env.example docker/.env
#   docker compose --env-file docker/.env up --build -d
# ─────────────────────────────────────────────────────────
#
# Quick secret generation:
#   ./scripts/generate-secrets.sh    # prints SECRET_KEY and POSTGRES_PASSWORD

# ── Required ────────────────────────────────────────────

# Strong random password for PostgreSQL superuser
POSTGRES_PASSWORD=changeme_use_strong_password

# JWT signing key — min 32 chars, generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_64_char_random_hex_string

# ── AI / OpenAI (required for AI features) ─────────────

OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ── Domains (Caddy reverse proxy) ──────────────────────

# Main app domain (no protocol)
DOMAIN=app.yourdomain.com

# API subdomain
API_DOMAIN=api.yourdomain.com

# Email for Let's Encrypt certificate notifications
CADDY_EMAIL=admin@yourdomain.com

# ── CORS & URLs ────────────────────────────────────────

# Comma-separated origins the API will accept requests from
ALLOWED_ORIGINS=https://app.yourdomain.com

# Publicly accessible frontend URL (used in emails, links)
APP_URL=https://app.yourdomain.com

# Publicly accessible API URL (used by the frontend at build time)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1

# ── Optional: Email (SMTP) ─────────────────────────────
# Leave blank to log emails to console instead.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@yourdomain.com

# ── Optional: Stripe Billing ───────────────────────────
# Leave blank to disable billing functionality.

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ── Debug — MUST be false in production ────────────────

DEBUG=false
