# Application
APP_NAME="BI SaaS Platform"
DEBUG=false
API_V1_PREFIX=/api/v1

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/bi_saas
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/bi_saas

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048

# File Upload
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=/tmp/bi_uploads

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRO_PRICE_ID=price_your_pro_plan_price_id
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_price_id
STRIPE_SUCCESS_URL=http://localhost:3000/billing?success=1
STRIPE_CANCEL_URL=http://localhost:3000/billing?canceled=1

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=noreply@yourdomain.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME="BI Platform"
SMTP_FROM_EMAIL=noreply@yourdomain.com
EMAIL_VERIFICATION_EXPIRE_HOURS=24
INVITE_TOKEN_EXPIRE_HOURS=72

# App URL (for email links)
APP_URL=http://localhost:3000

# Subscriptions
FREE_PLAN_MAX_DATASETS=5
FREE_PLAN_MAX_ROWS=10000
FREE_PLAN_MAX_QUERIES_PER_DAY=20
PRO_PLAN_MAX_DATASETS=50
PRO_PLAN_MAX_ROWS=500000
PRO_PLAN_MAX_QUERIES_PER_DAY=500
