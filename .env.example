# ────────────────────────────────────────────────
# Required
# ────────────────────────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-32+-character-string

# Async PostgreSQL URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5434/bi_saas

# Synchronous URL for Alembic migrations
SYNC_DATABASE_URL=postgresql://postgres:changeme@localhost:5434/bi_saas

# OpenAI key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ────────────────────────────────────────────────
# Optional — App
# ────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
DEBUG=false

# ────────────────────────────────────────────────
# Optional — Email (leave blank to log emails to console)
# ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@yourdomain.com

# ────────────────────────────────────────────────
# Optional — Stripe (leave blank to disable billing)
# ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ────────────────────────────────────────────────
# Optional — Docker postgres password override
# ────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme

# ────────────────────────────────────────────────
# Frontend (Next.js public env)
# ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
